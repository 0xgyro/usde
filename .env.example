# Copy to `.env`. Never commit real keys.

PRIVATE_KEY=0x...

TOKEN_NAME=USDE
TOKEN_SYMBOL=USDE

# Mainnet: set to your Gnosis Safe (or equivalent). Empty / zero uses deployer.
TOKEN_ADMIN=0x0000000000000000000000000000000000000000

# Mint cap in base units (6 decimals). 0 = uncapped on-chain.
USDE_MAX_SUPPLY=0

# Seconds before default-admin transfer can be accepted. Mainnet default in script: 172800 (48h).
# Use 0 only for Anvil/tests.
USDE_ADMIN_TRANSFER_DELAY=172800
